# ComfyUI connection
COMFYUI_URL=http://localhost:8188
PUBLIC_COMFYUI_URL=http://localhost:8188

# MCP Server binding (use 0.0.0.0 in Docker, 127.0.0.1 for local-only)
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9000

# Asset management
COMFY_MCP_ASSET_TTL_HOURS=24
COMFY_MCP_WORKFLOW_DIR=./workflows

# Response size limit (MB)
COMFYUI_MAX_RESPONSE_MB=100
